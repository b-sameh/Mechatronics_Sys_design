#include <WiFi.h>
#include <WiFiClientSecure.h>
#include <PubSubClient.h>
#include <ESP32Servo.h> // Ensure this is installed in Wokwi Library Manager

// ==========================================
// 1. GLOBAL SCOPE (This is what was missing!)
// ==========================================
const char* ssid = "Wokwi-GUEST";
const char* password = "";

// Replace these with your actual HiveMQ Cloud details
const char* mqtt_server = "ab08b93ba41c424c9a36ad7495893579.s1.eu.hivemq.cloud"; 
const char* mqtt_user = "Mech.design.project";
const char* mqtt_pass = "Hussein2862004";
const int mqtt_port = 8883;

// --- Servo Configuration ---
Servo myServo;
const int SERVO_PIN = 18; 
const char* servo_topic = "robot/arm/servo"; 

WiFiClientSecure espClient;
PubSubClient client(espClient);


// ==========================================
// 2. MQTT Callback (Runs when message arrives)
// ==========================================
void callback(char* topic, byte* payload, unsigned int length) {
  String message;
  for (int i = 0; i < length; i++) { 
    message += (char)payload[i]; 
  }
  
  int angle = message.toInt(); // Convert string like "90" to integer 90
  
  if (angle >= 0 && angle <= 180) {
    myServo.write(angle);
    Serial.print("Moving Servo to: ");
    Serial.println(angle);
  }
}


// ==========================================
// 3. Main Setup
// ==========================================
void setup() {
  Serial.begin(115200);
  myServo.attach(SERVO_PIN, 500, 2400); 
  
  Serial.print("Connecting to WiFi");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { 
    delay(500); 
    Serial.print("."); 
  }
  Serial.println("\nWiFi Connected!");
  
  espClient.setInsecure(); // Required for Wokwi simulation
  client.setServer(mqtt_server, mqtt_port);
  client.setCallback(callback);
}


// ==========================================
// 4. Main Loop
// ==========================================
void loop() {
  if (!client.connected()) {
    Serial.println("Connecting to HiveMQ...");
    
    // Connect with your defined credentials
    if (client.connect("ServoTestClient", mqtt_user, mqtt_pass)) { 
      Serial.println("Connected to Broker!");
      client.subscribe(servo_topic);
    } else {
      Serial.print("Failed, state: ");
      Serial.print(client.state());
      Serial.println(" Retrying in 5s...");
      delay(5000);
    }
  }
  client.loop();
}